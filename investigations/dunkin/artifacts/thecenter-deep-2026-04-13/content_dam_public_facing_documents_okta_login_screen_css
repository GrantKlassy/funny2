#login-bg-image-id {
    width: 100%;
    height: 100%;
    background-position: center !important;
    background-size: cover !important;
}
.login-bg-image.tb--background {
    background-color: #FFFFFF !important;
}
@media screen and (max-width: 1100px) {
    #login-bg-image-id {
        background-size: contain !important;
    }
}
@media only screen and (max-height: 750px) {
    #okta-sign-in {
        margin-top: 50px !important;
    }
}
#okta-sign-in .auth-org-logo {
    max-height: 70px !important;
}
#okta-sign-in .auth-org-logo {
    max-width: 300px !important;
}
#okta-sign-in.no-beacon .auth-header {
    padding-top: 20px !important;
    padding-bottom: 20px !important;
}
@media only screen and (max-width: 1100px) {
    #okta-sign-in.no-beacon .auth-header {
        padding: 20px !important;
    }
}
.o-form-button-ba .tb--button, .o-form-button-bar .button-primary {
    background: #F04DA3 !important;
    border-color: #000000 !important;
}
#okta-sign-in.auth-container h2, #okta-sign-in .o-form label {
    color: #75706E !important;
}
.auth-footer a[data-se="help"] {
    display: none !important;
}
