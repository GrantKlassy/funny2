<body>
    <div class="flexbox login">
        <div class="login-wrapper">
            <div class="login-form-wrapper">
                <div class="RAPLogo-container" style="text-align:center;max-width:100%">
                    <img src="/images/DunkinRAPLogo.png" loading="lazy" alt="" class="RAPlogo-icon">
                    <h2 class="RAP-app-name1">RESTAURANT ADMINISTRATION PORTAL</h2>
                    <h2 class="RAP-app-name2">(RAP)</h2>
                </div>
                
                <h1 class="RAPlogin-heading">Sign In with</h1>
                    <div data-duration-in="300" data-duration-out="100" class="login-tabs w-tabs">
                        <div class="login-tabs-content w-tab-content">
                            <div data-w-tab="Tab 1" class=" w-tab-pane w--tab-active">
                                <div class="login-form w-form">
                                    <form method="post" id="CrunchTime-email-form" name="email-form" data-name="Email Form" class="login-content-block" action="/user/logincrunchtime">
                                        <div class="form-input-wrapper">
                                            <div class="input-field-label-wrapper RAP-input-wrapper"><label for="Username" class="login-field-label"></label><label for="Username-3" class="field-label">Username</label></div>
                                            <input type="text" class="login-input-field w-input" maxlength="256" name="Username" data-name="Username" id="Username" required>
                                        </div>
                                        <div class="form-input-wrapper">
                                        <div class="input-field-label-wrapper RAP-input-wrapper"><label for="Password" class="login-field-label"></label><label for="Username-3" class="field-label">Password</label></div>
                                        <input type="password" class="login-input-field w-input" maxlength="256" name="Password" data-name="Password" id="Password" required>
                                    </div>
                                        <div class="form-input-wrapper">
                                            <div class="input-field-label-wrapper RAP-input-wrapper"><label for="EntityID" class="login-field-label"></label><label for="Username-3" class="field-label">EntityID</label></div>
                                            <input type="number" class="login-input-field w-input" maxlength="10" name="EntityID" data-name="EntityID" id="EntityID" required>
                                        </div>
                                    <input type="submit" id="loginCrunchTimeButton" value="Login" onclick="return loginCrunchTime();" data-wait="Please wait..." class="login-button w-button">
                                    <input name="__RequestVerificationToken" type="hidden" value="CfDJ8DAXReN4K_NOnwGbf9eLPyXsgXdoxG4DKczF7LaXH8dfkXQXUI6qAkZ4w2mJ5NQyCCv0MNG5XQq6XgT3HE-dNXPdEhSlWHqJDykBM86gXoTKRGbzKJ4JsBW8OBOYjRQcEF2Hn9r1rPpcR0IbpUnjzfA" /></form>
                                    <div class="w-form-done">
                                        <div>Thank you! Your submission has been received!</div>
                                    </div>
                                    <div class="w-form-fail">
                                        <div>Oops! Something went wrong while submitting the form.</div>
                                    </div>
                                    <div id="errorDiv2" class="error-label">
                                        <span id="ErrorMsg2"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="login-instruction">
                        <strong><em>Login Instruction:</em></strong><br>Use your <strong>CrunchTime</strong> login information to sign in<br>
                        <div><strong>Entity ID - </strong>Enter your four digit<strong> CrunchTime </strong>entity id, ex.0022,1234.<br></div>
                </div>
            </div>
                    <div class="sphere-wrapper">
                        <div class="sphere-block">
                            <div class="sphere-map"></div>
                        </div>
                    </div>
                </div>
        <div class="globe-bg"></div>
        <div  id="loader" class="preloader">
            <div class="preloader-gif"><img src="/images/preloader-gif.gif" loading="lazy" alt=""></div>
        </div>
    </div>
    <script type="text/javascript">
        $(document).ready(function () {
            $("#otpDiv").hide();
            $("#errorDiv").hide();
            $("#errorDiv1").hide();
            $("#errorDiv2").hide();
            $("#emailDiv").show();
            $("#loader").hide();
        });

        // function OTPLoginPage() {
        //     window.location.replace('/User/OTPLoginPage');
        // }

        function loginCrunchTime() {
            var loginButton = $('#loginCrunchTimeButton');

            var entityID = '';

            if ($('#EntityID').val() != undefined && $('#EntityID').val() != '') {
                entityID = $('#EntityID').val();
            }
           
            var credential = {
                'UserName': $("#Username").val(),
                'Password': $("#Password").val(),
                'EntityID': entityID,
                'CrunchTimeURL': ''
            };

            if ($("#Username").val() === "") {
                $("#errorDiv2").show();
                $("#ErrorMsg2").text("User name is mandatory.");
                return false;
            }
            else if ($("#Password").val() === "") {
                $("#errorDiv2").show();
                $("#ErrorMsg2").text("Password is mandatory.");
                return false;
            } else if ($('#EntityID').val() != undefined && $('#EntityID').val() == '') {
                $("#errorDiv2").show();
                $("#ErrorMsg2").text("EntityID is mandatory.");
                return false;
            }
            $("#loader").show();
            DisableControl(loginButton);

            $.ajax({
                method: "POST",
                beforeSend: function (request) {
                    request.setRequestHeader("RequestVerificationToken", $("[name='__RequestVerificationToken']").val());
                },
                url: '/User/LogInCrunchTime',
                data: JSON.stringify(credential),
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    if (response !== null && response.result === true) {
                        setTimeout(function () {
                            EnableControl(loginButton);
                        }, 30000);
                        window.location.replace("/dashboard");
                        return false;
                    }
                    else {
                        EnableControl(loginButton);
                        $("#Username").val('');
                        $("#Password").val('');
                        $("#EntityID").val('');
                        $("#errorDiv2").show();
                        $("#loader").hide();
                        $("#ErrorMsg2").text(response.errorMsg);
                    }
                }
            });

            return false;
        }

        function DisableControl(control) {
            control.prop('disabled', true);
            control.addClass('disable-control');
        }

        function EnableControl(control) {
            control.prop('disabled', false);
            control.removeClass('disable-control');
        }

        function sendNewMail() {
            var sendButton = $("#SendOTPButton");
            DisableControl(sendButton);

            var hasError = false;
            let emailText = $("#EmailAddress").val();
            var emailReg = /^([\w-\.]+@([\w-]+\.)+[\w-]{2,4})?$/;

            if (!emailReg.test(emailText)) {
                $("#errorDiv").show();
                $("#ErrorMsg").text("Enter valid email.");
                hasError = true;
            }
            else if (emailText === "") {
                $("#errorDiv").show();
                $("#ErrorMsg").text("Email is mandatory.");
                hasError = true;
            }

            if (hasError == true) {
                EnableControl(sendButton);
                return false;
            }
            $("#loader").show();
            var postData = { email: emailText };

            $.ajax({
                method: "GET",
                beforeSend: function (request) {
                    request.setRequestHeader("RequestVerificationToken", $("[name='__RequestVerificationToken']").val());
                },
                url: '/User/GenrateOTPForUser',
                data: postData,
                dataType: 'json',
                traditional: true,
                success: function (response) {
                    if (response !== null && response.result === true) {
                        $("#MyEmail").text(" " + emailText);
                        $("#emailDiv").hide();
                        $("#otpDiv").show();
                        $("#loader").hide();
                        setTimeout(function () {
                            EnableControl(sendButton);
                        }, 30000);
                    }
                    else {
                        EnableControl(sendButton);
                        $("#errorDiv").show();
                        $("#loader").hide();
                        $("#ErrorMsg").text(response.errorMessage);
                    }
                }
            });
            return false;
        }

        function RegenerateOTP() {
            var resendButton = $("#ResendOTPButton");
            resendButton.removeClass("resend-link");
            resendButton.addClass("disable-control-link-button");
            resendButton.removeAttr("href");
            $("#loader").show();

            let emailText = $("#EmailAddress").val();

            var postData = { email: emailText };

            $.ajax({
                method: "GET",
                beforeSend: function (request) {
                    request.setRequestHeader("RequestVerificationToken", $("[name='__RequestVerificationToken']").val());
                },
                url: '/User/GenrateOTPForUser',
                data: postData,
                dataType: 'json',
                traditional: true,
                success: function (response) {
                    if (response !== null && response.result === true) {
                        $("#MyEmail").text(" " + emailText);
                        $("#emailDiv").hide();
                        $("#otpDiv").show();
                        $("#loader").hide();
                        setTimeout(function () {
                            resendButton.removeClass("disable-control-link-button");
                            resendButton.addClass("resend-link");
                            resendButton.attr("href", "javascript:RegenerateOTP();");
                        }, 30000);
                    }
                    else {
                        resendButton.removeClass("disable-control-link-button");
                        resendButton.addClass("resend-link");
                        resendButton.attr("href", "javascript:RegenerateOTP();");
                        $("#errorDiv1").show();
                        $("#loader").hide();
                        $("#ErrorMsg1").text(response.errorMessage);
                    }
                }
            });
            return false;
        }

    </script>
</body>
</html>